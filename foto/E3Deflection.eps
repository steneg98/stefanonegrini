/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 840
  /ImageMatrix [1120 0 0 840 0 0]
  /Width 1120
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
